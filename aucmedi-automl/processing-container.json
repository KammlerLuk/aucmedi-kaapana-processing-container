{
    "name": "aucmedi-automl",
    "description": "AUCMEDI AutoML Processing Container for Kaapana",
    "templates": [
        {
            "identifier": "default",
            "description": "Executes the AutoML pipeline on the input data and produces the output data.",
            "inputs": [
                {"name": "training", "mounted_path": "/home/kaapana/aucmedi.data/training"},
                {"name": "test", "mounted_path": "/home/kaapana/aucmedi.data/test"}
            ],
            "outputs": [
                {"name": "output", "mounted_path": "/home/kaapana/aucmedi.data"}
            ], 
            "env": [],
            "command": ["aucmedi"]  
        }
    ]
}