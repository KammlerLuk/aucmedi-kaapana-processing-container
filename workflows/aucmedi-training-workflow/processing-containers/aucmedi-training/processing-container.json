{
    "name": "aucmedi-automl-training",
    "description": "AUCMEDI AutoML Training Processing Container for Kaapana",
    "templates": [
        {
            "identifier": "AUCMEDI_AutoML_training",
            "description": "Trains a model through the AutoML pipeline.",
            "inputs": [
                {"name": "training", "mounted_path": "/home/kaapana/aucmedi.data/training"},
                {"name": "test", "mounted_path": "/home/kaapana/aucmedi.data/test"}
            ],
            "outputs": [
                {"name": "output", "mounted_path": "/home/kaapana/aucmedi.data"}
            ], 
            "env": [],
            "command": ["training"]  
        },
        {
            "identifier": "AUCMEDI_AutoML_evaluation",
            "description": "Evaluates the model in the AutoML pipeline.",
            "inputs": [
                {"name": "training", "mounted_path": "/home/kaapana/aucmedi.data/training"},
                {"name": "test", "mounted_path": "/home/kaapana/aucmedi.data/test"}
            ],
            "outputs": [
                {"name": "output", "mounted_path": "/home/kaapana/aucmedi.data"}
            ], 
            "env": [],
            "command": ["evaluation"]  
        }
    ]
}